# backup.env.example — copiá este archivo a `backup.env` y completá los valores.
#
# `backup.env` está en .gitignore. NO LO COMMITEES.
# Para configurar:
#   cp backup.env.example backup.env
#   # editar backup.env con valores reales

# ── VPS productivo (origen del pull) ───────────────────────────────────────

# IP o hostname del VPS Hetzner.
VPS_HOST=

# Usuario SSH en el VPS (root o el que use el deploy).
VPS_USER=root

# Puerto SSH (default 22, dejá vacío para usar el default).
VPS_PORT=22

# Path absoluto al p2p_normalized.db en el VPS. Tentativo hasta cerrar deploy.
VPS_DB_PATH=/opt/binance_p2p/p2p_normalized.db

# Path al directorio snapshots/ en el VPS. Tentativo hasta cerrar deploy.
VPS_SNAPSHOTS_PATH=/opt/binance_p2p/snapshots

# ── SSH key ────────────────────────────────────────────────────────────────

# Path a la SSH private key para autenticar contra el VPS.
# La pública correspondiente debe estar en el VPS en
# /root/.ssh/authorized_keys (o ~/.ssh/authorized_keys del VPS_USER).
# Soporta ~ (se expande con os.path.expanduser).
SSH_KEY_PATH=~/.ssh/id_ed25519_hetzner

# ── Local (destino del pull) ───────────────────────────────────────────────

# Directorio raíz local donde viven los backups.
# Se crean subdirs db/ y snapshots/ adentro automáticamente.
LOCAL_BACKUP_ROOT=~/backups
